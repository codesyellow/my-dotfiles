#!/usr/bin/env bash

check_dependencies() {
  for cmd in "$@"; do
    command -v "$cmd" >/dev/null || {
      echo "Missing dependency: $cmd"
      exit 1
    }
  done
}

check_dependencies jq wl-copy dunstify niri

window=$(niri msg focused-window)

[ -z "$window" ] && exit 1

app_id=$(echo "$window" | jq -r '.app_id // empty')
title=$(echo "$window" | jq -r '.title // empty')
pid=$(echo "$window" | jq -r '.pid // empty')

if [ -n "$app_id" ]; then
  echo "APP_ID=$app_id"
  echo "APP_ID=$app_id" | wl-copy
elif [ -n "$title" ]; then
  echo "TITLE=$title"
  echo "TITLE=$title" | wl-copy
else
  echo "PID=$pid"
  echo "PID=$pid" | wl-copy
fi

dunstify "App info copied (niri)"

