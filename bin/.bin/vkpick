#!/usr/bin/env python3
import subprocess
import os
import shutil

HOME = os.path.expanduser("~")
CONFIG_PATH = f"{HOME}/.config/lsfg-vk/conf.toml"
vk_names = subprocess.run(['lsfg_games'], capture_output=True, text=True).stdout

TEMPLATE = '''
[[game]]
exe = "{exe_name}"
multiplier = 2
flow_scale = 1.0
performance_mode = true
hdr_mode = false
experimental_present_mode = "fifo"
'''

def name_exist(name):
    exe_name = f'exe = "{name}"'
    with open(CONFIG_PATH, 'r') as f:
        data = f.read()
        return exe_name in data

try:
    # Substituindo wmenu pelo rofi
    # -dmenu: faz o rofi agir como um menu genérico
    # -i: ignorar diferença entre maiúsculas/minúsculas
    # -p: define o texto do prompt
    # -l: limita a quantidade de linhas visíveis (opcional no rofi, mas mantido conforme seu original)
    process_menu = subprocess.run(
        ["rofi", "-dmenu", "-i", "-p", "Process Name", "-l", "10"], 
        input=vk_names, 
        capture_output=True, 
        text=True,
        check=True
    )

    name = process_menu.stdout.strip()

    if name: 
        if os.path.exists(CONFIG_PATH):
            if name_exist(name):
                print(f"'{name}' already included")
            else:
                new_template = TEMPLATE.format(exe_name=name)
                shutil.copy2(CONFIG_PATH, CONFIG_PATH + ".backup")
                print("Backup done")

                with open(CONFIG_PATH, "a") as f:
                    f.write(new_template)
                    print(f"'{name}' was added!")
        else:
            print("Config path doesn't exist")
    else:
        print("Process name was empty")

except subprocess.CalledProcessError:
    # Isso acontece se você fechar o Rofi (ESC) sem selecionar nada
    print("Selection cancelled")
